APP_ADDR=:8080

MYSQL_HOST=<mysql-server-host>
MYSQL_PORT=3306
MYSQL_DATABASE=<mysql-database>
MYSQL_USER=<mysql-user>
MYSQL_PASSWORD=<set-a-strong-password>

INIT_ADMIN_EMAIL=admin@zenmind.cc
INIT_ADMIN_PASSWORD=<set-a-strong-admin-password>

COOKIE_NAME=zenmind_session
COOKIE_SECURE=false
SESSION_TTL=24h
SQLITE_DB_PATH=/data/data.sqlite

GOOGLE_CLIENT_ID=
GOOGLE_DESKTOP_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://<your-domain>/api/v1/auth/google/callback
AUTH_SUCCESS_URL=https://<your-domain>/
AUTH_FAILURE_URL=https://<your-domain>/auth/failure
